# SafeLens — PUBLIC environment variables (example).
#
# ONLY public VITE_* values belong in this file. NEVER put real secrets here
# (no RunPod / Cloudflare / DeepSeek / Supabase service-role keys). Anything
# prefixed VITE_ is inlined into the browser bundle at build time, so it must be
# safe to expose publicly. Copy to `.env` and fill in your own public values.

# Supabase (public anon/publishable values only)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Cloudflare Worker `/detect` gateway URL (public gateway, NOT the raw RunPod
# endpoint and NOT an API key). Optional — falls back to the built-in default.
VITE_VISION_HTTP_DETECT_URL=
# Legacy alias, still honored as a fallback when the new var is unset.
VITE_EDGECRAFT_HTTP_DETECT_URL=

# ── Risk-aware feature flags. These now default ON in the app; set any to
# "false" to disable that piece for a build. (Risk overlays only show data when
# the worker actually emits risk fields — otherwise detection renders normally.)
VITE_RISK_AWARE_OVERLAY=true
VITE_WORKER_SCENE_RISKS=true
VITE_RISK_DEBUG_PANEL=true
VITE_SHOW_CONTROL_HIERARCHY=true
VITE_SHOW_PROVENANCE=true
VITE_CAMERA_PRIVACY_NOTICE=true

# ── HSE Live monitoring flags (all default OFF). Public booleans only.
# Reasoner candidate lane = surface unlinked reasoner scene suggestions as
# advisory-only. Local alerts = legacy on-device DeepSeek/rules alerts (haptics,
# incidents, AlertFeed in HSE mode). Default OFF means worker/reasoner scene
# risks are the single source of truth shown in Live HSE.
#
# NOTE: the worker chooses the live scene reasoner model (e.g. Gemini); the app
# stays model-agnostic. The canonical generic VITE_HSE_REASONER_* names below
# WIN when set; the legacy VITE_HSE_QWEN_* names are still honored as fallbacks
# only when the canonical is unset. NEVER put a Gemini/Google API key here.
VITE_HSE_REASONER_CANDIDATE_LANE_ENABLED=false
VITE_HSE_SHOW_REASONER_CANDIDATES=false
VITE_HSE_LOCAL_ALERTS_ENABLED=false

# ── HSE reasoner scene-reasoning heartbeat (HSE Live mode only).
# Sends one current frame to the worker reasoner every INTERVAL_MS via the
# existing Cloudflare /detect path. Single-in-flight, latest-frame-only,
# visibility-paused. Never replaces the YOLO live detector loop. Public
# booleans/numbers only — no secrets here.
VITE_HSE_REASONER_HEARTBEAT_ENABLED=true
# 5000 ms: reduce Gemini spam (worker rate-limits + reasons from live frames).
VITE_HSE_REASONER_HEARTBEAT_INTERVAL_MS=5000
VITE_HSE_REASONER_HEARTBEAT_MIN_INTERVAL_MS=1000
# 12000 ms: covers Gemini ~5–12s latency so the last-good reasoner latch stays
# fresh between arrivals and keeps coloring boxes while the camera is on.
VITE_HSE_REASONER_RESULT_TTL_MS=12000
# Legacy Qwen-named heartbeat vars are still honored when the canonical
# VITE_HSE_REASONER_* equivalents above are unset, e.g.:
#   VITE_HSE_QWEN_HEARTBEAT_ENABLED, VITE_HSE_QWEN_HEARTBEAT_INTERVAL_MS,
#   VITE_HSE_QWEN_HEARTBEAT_MIN_INTERVAL_MS, VITE_HSE_QWEN_RESULT_TTL_MS.

# YOLO continuous detect + event-driven AI reasoning. Default false: the
# Live HSE /detect request does NOT ask the worker for raw pose keypoints
# (pose models hallucinate on furniture/reflections/plants). Set true to opt
# back in for debug/person-specific tests.
VITE_HSE_REQUEST_POSE=false

# Build Mode hand-pointer fallback. Default false: only MediaPipe Hand
# Landmarker drives the pointer. Set true to allow backend pose wrists /
# pose-debug wrists as a fallback (subject to existing strict validation).
VITE_BUILD_BACKEND_WRIST_FALLBACK=false

# HSE capture (optional). Defaults: 512 / 0.7. For better small-object recall
# (cup/can/glass edges) try 960 / 0.78. Clamped to [256,1280] / [0.4,0.92].
# Aspect ratio is always preserved — overlay alignment is unchanged.
VITE_HSE_CAPTURE_MAX_SIDE=
VITE_HSE_CAPTURE_QUALITY=
